{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JDSource/clearmarket/schema/clearmarket-schema.json",
  "title": "ClearMarket Enriched Market Record",
  "description": "Structured intelligence record for a prediction market, combining commodity data with enrichment fields that don't exist in platform APIs.",
  "type": "object",
  "required": [
    "reference_id",
    "platform",
    "platform_market_id",
    "question",
    "category",
    "price_snapshot",
    "resolution_logic",
    "temporal_context",
    "resolution_source",
    "cross_platform_link",
    "related_markets"
  ],
  "properties": {
    "reference_id": {
      "type": "string",
      "description": "Canonical event identifier. Master key across platforms. Format: CATEGORY-TOPIC-VARIANT (e.g., US-RECESSION-2026, FOMC-JUNE-2026).",
      "pattern": "^[A-Z0-9-]+$"
    },
    "description": {
      "type": "string",
      "description": "Human-readable summary of the market in 1-2 sentences. Includes what the market asks and its current implied probability."
    },
    "platform": {
      "type": "string",
      "enum": ["polymarket", "kalshi"],
      "description": "Source platform."
    },
    "platform_market_id": {
      "type": "string",
      "description": "Native identifier on the source platform. Polymarket: slug or conditionId. Kalshi: ticker."
    },
    "question": {
      "type": "string",
      "description": "Normalized plain-English version of what the market asks."
    },
    "category": {
      "type": "string",
      "enum": ["macro", "geopolitics", "politics", "crypto", "sports"],
      "description": "Primary category."
    },
    "price_snapshot": {
      "type": "object",
      "description": "Market pricing for both Yes and No outcomes, plus implied probability. Matches convention used by both Polymarket and Kalshi APIs.",
      "required": ["yes", "no", "implied_probability", "volume", "as_of"],
      "properties": {
        "yes": {
          "type": "object",
          "description": "Yes-side pricing.",
          "required": ["last_price"],
          "properties": {
            "last_price": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Last traded price for Yes outcome (0-1)."
            },
            "best_bid": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1,
              "description": "Best bid for Yes outcome."
            },
            "best_ask": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1,
              "description": "Best ask for Yes outcome."
            }
          }
        },
        "no": {
          "type": "object",
          "description": "No-side pricing.",
          "required": ["last_price"],
          "properties": {
            "last_price": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Last traded price for No outcome (0-1)."
            },
            "best_bid": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1,
              "description": "Best bid for No outcome."
            },
            "best_ask": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1,
              "description": "Best ask for No outcome."
            }
          }
        },
        "implied_probability": {
          "type": "object",
          "description": "Market-implied probability of each outcome. In prediction markets, price equals probability — a Yes price of 0.35 means the market assigns a 35% chance of the event occurring.",
          "required": ["yes", "no"],
          "properties": {
            "yes": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Implied probability of Yes outcome (0-1)."
            },
            "no": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Implied probability of No outcome (0-1)."
            }
          }
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "description": "Total volume traded (USD or USDC)."
        },
        "liquidity": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Current liquidity in order book (USD or USDC)."
        },
        "as_of": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of this snapshot. Prices are not real-time."
        }
      }
    },
    "resolution_logic": {
      "type": "object",
      "description": "Parsed resolution criteria. The #1 source of disputes and losses.",
      "required": ["summary", "triggers", "trigger_logic"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "Plain-English summary of what triggers resolution."
        },
        "triggers": {
          "type": "array",
          "description": "Machine-readable resolution triggers.",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["metric", "announcement", "event", "date"],
                "description": "Trigger type."
              },
              "description": {
                "type": "string",
                "description": "What this trigger checks."
              },
              "metric": {
                "type": ["string", "null"],
                "description": "Specific metric name (for metric triggers)."
              },
              "threshold": {
                "type": ["string", "null"],
                "description": "Threshold value or condition (e.g., '< 0.0%', '>= 50 bps')."
              },
              "source": {
                "type": ["string", "null"],
                "description": "Official data source for this trigger."
              },
              "deadline": {
                "type": ["string", "null"],
                "description": "When this trigger must occur by."
              }
            }
          }
        },
        "trigger_logic": {
          "type": "string",
          "enum": ["AND", "OR", "SINGLE"],
          "description": "How multiple triggers combine. SINGLE if only one trigger."
        },
        "exclusions": {
          "type": "array",
          "description": "What explicitly does NOT count for resolution.",
          "items": {
            "type": "string"
          }
        },
        "ambiguity_notes": {
          "type": ["string", "null"],
          "description": "Edge cases, revision policies, or known ambiguities in resolution criteria."
        }
      }
    },
    "temporal_context": {
      "type": "object",
      "description": "Timing structure. Closes (trading stops) and resolves (payout) are different events.",
      "required": ["closes", "resolves"],
      "properties": {
        "closes": {
          "type": "string",
          "format": "date",
          "description": "Date trading closes."
        },
        "resolves": {
          "type": "string",
          "description": "Date or approximate date the market resolves. Use ~ prefix for estimates (e.g., '~2027-01-30')."
        },
        "catalyst_dates": {
          "type": "array",
          "description": "Real-world events that move price before resolution.",
          "items": {
            "type": "object",
            "required": ["date", "event"],
            "properties": {
              "date": {
                "type": "string",
                "format": "date",
                "description": "Date of the catalyst event."
              },
              "event": {
                "type": "string",
                "description": "Description of the catalyst event."
              }
            }
          }
        },
        "days_to_resolution": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Days from snapshot to expected resolution."
        }
      }
    },
    "resolution_source": {
      "type": "object",
      "description": "Who determines the outcome and how.",
      "required": ["name", "type", "mechanism"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the resolution authority (e.g., 'BEA', 'Federal Reserve', 'NBER')."
        },
        "type": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "government_statistical_agency",
                "central_bank",
                "government",
                "regulatory_body",
                "international_organization",
                "news_organization",
                "financial_data_provider",
                "platform_staff",
                "other"
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "government_statistical_agency",
                  "central_bank",
                  "government",
                  "regulatory_body",
                  "international_organization",
                  "news_organization",
                  "financial_data_provider",
                  "platform_staff",
                  "other"
                ]
              },
              "minItems": 2
            }
          ],
          "description": "Type of resolution authority. Use a string for single-source markets, an array for markets resolved by multiple source types."
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL of the resolution authority."
        },
        "mechanism": {
          "type": "string",
          "description": "How resolution is executed on this platform. Kalshi: 'Centralized (CFTC-regulated staff determination)'. Polymarket: 'UMA optimistic oracle ($X dispute bond)'."
        }
      }
    },
    "cross_platform_link": {
      "type": ["object", "null"],
      "description": "Equivalent market on another platform. Null = no equivalent exists (coverage gap).",
      "properties": {
        "linked_platform": {
          "type": "string",
          "enum": ["polymarket", "kalshi"],
          "description": "The other platform."
        },
        "linked_market_id": {
          "type": ["string", "null"],
          "description": "Market ID on the linked platform. Null if no direct equivalent."
        },
        "match_confidence": {
          "type": ["string", "null"],
          "enum": ["exact", "close", "proxy", null],
          "description": "How closely the linked market matches. exact = same question and resolution. close = same question, different resolution details. proxy = related but structurally different."
        },
        "structural_notes": {
          "type": ["string", "null"],
          "description": "Why structures differ, or why no equivalent exists. A null linked_market_id with structural notes is itself a signal — it documents a coverage gap."
        }
      }
    },
    "related_markets": {
      "type": "array",
      "description": "Connected markets on the same platform.",
      "items": {
        "type": "object",
        "required": ["market_id", "relationship_type"],
        "properties": {
          "market_id": {
            "type": "string",
            "description": "Market ID on the same platform."
          },
          "relationship_type": {
            "type": "string",
            "enum": ["temporal_cluster", "parlay", "comparison", "causal_indicator", "hedge"],
            "description": "How this market relates."
          },
          "notes": {
            "type": ["string", "null"],
            "description": "Why this relationship matters for trading or analysis."
          }
        }
      }
    }
  }
}
